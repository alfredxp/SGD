@model IEnumerable<SGDApp.Models.LogActividades>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.LogActividadId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LogActividadFecha)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LogActividadAccion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TaskId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UsuarioId)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.LogActividadId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LogActividadFecha)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LogActividadAccion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TaskId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UsuarioId)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new {  id=item.LogActividadId  }) |
                @Html.ActionLink("Details", "Details", new {  id=item.LogActividadId  }) |
                @Html.ActionLink("Delete", "Delete", new {  id=item.LogActividadId  })
            </td>
        </tr>
}
    </tbody>
</table>
