@model IEnumerable<SGDApi.Models.Comentario>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Contenido)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Task)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaUltimaRevision)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaOrigen)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UsuariosModificacion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UsuariosCreador)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Contenido)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Task.TaskId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FechaUltimaRevision)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FechaOrigen)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UsuariosModificacion.UsuarioContrasena)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UsuariosCreador.UsuarioContrasena)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ComentarioId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ComentarioId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ComentarioId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
