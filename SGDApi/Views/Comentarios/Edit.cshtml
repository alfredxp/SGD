@model SGDApi.Models.Comentario

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Comentario</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ComentarioId" />
            <div class="form-group">
                <label asp-for="Contenido" class="control-label"></label>
                <input asp-for="Contenido" class="form-control" />
                <span asp-validation-for="Contenido" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TaskId" class="control-label"></label>
                <select asp-for="TaskId" class="form-control" asp-items="ViewBag.TaskId"></select>
                <span asp-validation-for="TaskId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FechaUltimaRevision" class="control-label"></label>
                <input asp-for="FechaUltimaRevision" class="form-control" />
                <span asp-validation-for="FechaUltimaRevision" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FechaOrigen" class="control-label"></label>
                <input asp-for="FechaOrigen" class="form-control" />
                <span asp-validation-for="FechaOrigen" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UsuarioModificacion" class="control-label"></label>
                <select asp-for="UsuarioModificacion" class="form-control" asp-items="ViewBag.UsuarioModificacion"></select>
                <span asp-validation-for="UsuarioModificacion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UsuarioCreador" class="control-label"></label>
                <select asp-for="UsuarioCreador" class="form-control" asp-items="ViewBag.UsuarioCreador"></select>
                <span asp-validation-for="UsuarioCreador" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
