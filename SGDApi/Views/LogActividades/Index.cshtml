@model IEnumerable<SGDApi.Models.LogActividades>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.LogActividadFecha)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LogActividadAccion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Task)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Usuarios)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.LogActividadFecha)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LogActividadAccion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Task.TaskId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Usuarios.UsuarioContrasena)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.LogActividadId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.LogActividadId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.LogActividadId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
