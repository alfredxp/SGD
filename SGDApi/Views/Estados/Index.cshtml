@model IEnumerable<SGDApi.Models.Estados>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.EstadoNombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EstadoCodigo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Task)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UsuarioModificacion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UsuarioCreador)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.EstadoNombre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EstadoCodigo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Task.TaskId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UsuarioModificacion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UsuarioCreador)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.EstadoId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.EstadoId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.EstadoId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
